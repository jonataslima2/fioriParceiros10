<mvc:View controllerName="fiori.z10bp.controller.Parceiros"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        <content>

            <List id="listaParceiros"
                  items="{/I_BusinessPartner}"
                  mode="SingleSelectMaster"
                  itemPress="aoSelecionarParceiro">

                <headerToolbar>
                    <OverflowToolbar >

                        <content>
                            <SearchField liveChange="aoPesquisarParceiro"/>
                        </content>

                    </OverflowToolbar>
                </headerToolbar>

                <items>
                    <StandardListItem title="{BusinessPartnerName}" description="{BusinessPartner}"
                                      type="Active"/>
                </items>

            </List>

        </content>
    </Page>
</mvc:View>
